# Local dev launcher - template.
# Copy this file to run-dev.ps1 and fill in your real values.
# run-dev.ps1 is gitignored; this template is committed.

# --- Database ---
$env:DB_URL = "jdbc:postgresql://localhost:5432/foodOrdering"
$env:DB_USERNAME = "postgres"
$env:DB_PASSWORD = "CHANGE_ME"

# --- JWT (must be at least 32 chars for HS256) ---
$env:JWT_SECRET = "CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS"
$env:JWT_EXPIRATION_MS = "3600000"

# --- Default admin seeded on first boot ---
$env:APP_ADMIN_EMAIL = "admin@food.com"
$env:APP_ADMIN_PASSWORD = "CHANGE_ME"
$env:APP_ADMIN_NAME = "Admin"

# --- Run the app ---
.\mvnw.cmd spring-boot:run
